#!/bin/bash
echo "🧪 Running tests before push..."
echo "  (skip with: git push --no-verify)"

cd "$(git rev-parse --show-toplevel)"

# タイムアウト120秒でテスト実行（macOS互換: gtimeoutがなければタイムアウトなし）
if command -v gtimeout &>/dev/null; then
    gtimeout 120 python -m pytest tests/ -q --tb=short 2>&1
elif command -v timeout &>/dev/null; then
    timeout 120 python -m pytest tests/ -q --tb=short 2>&1
else
    python -m pytest tests/ -q --tb=short 2>&1
fi
RESULT=$?

if [ $RESULT -ne 0 ]; then
    echo ""
    echo "❌ Tests failed! Push aborted."
    echo "  Fix the failing tests, or use 'git push --no-verify' to force push."
    exit 1
fi

echo "✅ All tests passed. Pushing..."
exit 0
